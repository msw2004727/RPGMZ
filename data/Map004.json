"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":250,"indent":0,"parameters":[{"name":"Move1","volume":90,"pitch":100,"pan":0}]},{"code":201,"indent":0,"parameters":[0,5,3,10,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":1,"walkAnime":true}],"x":4,"y":8},{"id":7,"name":"韓村長","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People2","direction":2,"pattern":1,"characterIndex":0},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"韓村長"]},{"code":401,"indent":1,"parameters":["回來啦。"]},{"code":401,"indent":1,"parameters":["你站在這屋裡，我就想起你小時候翻窗進來偷看公文的模樣。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"韓村長"]},{"code":401,"indent":1,"parameters":["別急著開口。"]},{"code":401,"indent":1,"parameters":["我先看看你今天是來幫忙，還是來給我添新麻煩。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"韓村長"]},{"code":401,"indent":1,"parameters":["你終於肯走正門了。"]},{"code":401,"indent":1,"parameters":["這很好，代表你比八歲那年懂事了一點點。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["韓村長_選單"]},{"code":102,"indent":0,"parameters":[["問村務","說說鄰居","翻我黑歷史","問東邊舊路","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問村務"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"韓村長"]},{"code":401,"indent":1,"parameters":["村務？簡單說，就是屋頂、糧袋、糾紛、路況、還有你們這群人的突發奇想。"]},{"code":401,"indent":1,"parameters":["韓村長三個字聽著威風，實際上像在拿一把小掃帚追著滿村火星跑。"]},{"code":401,"indent":1,"parameters":["但這村是咱的家，再碎的事，也得有人慢慢收。"]},{"code":119,"indent":1,"parameters":["韓村長_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"韓村長"]},{"code":401,"indent":1,"parameters":["阿安做事細，阿青跑得快，老周嘴上怪，腦子卻比誰都藏得多。"]},{"code":401,"indent":1,"parameters":["阿梅看似只管旅館，實際上半村人的身體和心情都在她眼底。"]},{"code":401,"indent":1,"parameters":["這村沒有誰真是局外人，每個人都牽著別人的日子。"]},{"code":119,"indent":1,"parameters":["韓村長_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"韓村長"]},{"code":401,"indent":1,"parameters":["你八歲那年爬上石像，還說要練「俯視天下步」。"]},{"code":401,"indent":1,"parameters":["結果腳一滑，嚇得半村人以為要改叫你「墜鷹」。"]},{"code":401,"indent":1,"parameters":["你如今還能站在這裡，已經是老天爺給村子的面子。"]},{"code":119,"indent":1,"parameters":["韓村長_選單"]},{"code":402,"indent":0,"parameters":[3,"問東邊舊路"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"韓村長"]},{"code":401,"indent":1,"parameters":["東邊那條舊路荒了些年，最近卻忽然有人繞去那邊。"]},{"code":401,"indent":1,"parameters":["我不喜歡沒來由的動靜，所以才讓阿青盯著，讓阿安備著。"]},{"code":401,"indent":1,"parameters":["你若真要插手，記著一件事：先把聽來的話分清，再決定要不要拔刀。"]},{"code":119,"indent":1,"parameters":["韓村長_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"韓村長"]},{"code":401,"indent":1,"parameters":["去吧。"]},{"code":401,"indent":1,"parameters":["別鬧事，這句話我對你說了十幾年，今天照說。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":9,"y":5}]}