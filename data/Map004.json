ers":["在戰場上被魔物追著跑的日子。"]},{"code":401,"indent":1,"parameters":["至少那時候不用寫公文。"]},{"code":119,"indent":1,"parameters":["選單"]},{"code":402,"indent":0,"parameters":[1,"村子最近還好嗎？"]},{"code":101,"indent":1,"parameters":["Actor3",2,0,2,"村長"]},{"code":401,"indent":1,"parameters":["還好？你說「還好」？"]},{"code":401,"indent":1,"parameters":["隔壁老周每天來投訴說民房1養貓擾民，"]},{"code":401,"indent":1,"parameters":["民房1的小桃又跑來哭訴說老周汙衊她！"]},{"code":101,"indent":1,"parameters":["Actor3",2,0,2,"村長"]},{"code":401,"indent":1,"parameters":["武器店的老王上禮拜把鐵錘砸到自己腳，"]},{"code":401,"indent":1,"parameters":["休了三天工，那三天沒人能買武器！"]},{"code":401,"indent":1,"parameters":["冒險者們差點暴動！"]},{"code":101,"indent":1,"parameters":["Actor3",2,0,2,"村長"]},{"code":401,"indent":1,"parameters":["酒館的老趙又讓客人賒帳，"]},{"code":401,"indent":1,"parameters":["帳本上的壞帳多到我看了想吐血......"]},{"code":101,"indent":1,"parameters":["Actor3",2,0,2,"村長"]},{"code":401,"indent":1,"parameters":["哦對了，東邊的密林最近魔物變多了，"]},{"code":401,"indent":1,"parameters":["北方的黑風寨也出了大事，"]},{"code":401,"indent":1,"parameters":["我還得想辦法加強村子的防禦......"]},{"code":101,"indent":1,"parameters":["Actor3",2,0,2,"村長"]},{"code":401,"indent":1,"parameters":["（揉太陽穴）"]},{"code":401,"indent":1,"parameters":["我真的好懷念以前只要揮劍就能解決問題的日子。"]},{"code":401,"indent":1,"parameters":["現在揮劍只會被告傷害罪。"]},{"code":119,"indent":1,"parameters":["選單"]},{"code":402,"indent":0,"parameters":[2,"沒事，打擾了"]},{"code":101,"indent":1,"parameters":["Actor3",2,0,2,"村長"]},{"code":401,"indent":1,"parameters":["嗯，沒事就好。"]},{"code":401,"indent":1,"parameters":["如果你是冒險者的話，出門小心點。"]},{"code":401,"indent":1,"parameters":["這世道不太平......"]},{"code":101,"indent":1,"parameters":["Actor3",2,0,2,"村長"]},{"code":401,"indent":1,"parameters":["（小聲）好羨慕你可以自由自在地冒險......"]},{"code":401,"indent":1,"parameters":["我也好想出去砍幾隻魔物放鬆一下......"]},{"code":401,"indent":1,"parameters":["（翻開帳本）唉，做夢吧。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"