parameters":[["你好啊","隔壁很吵嗎？","告辭"],2,0,2,0]},{"code":402,"indent":0,"parameters":[0,"你好啊"]},{"code":101,"indent":1,"parameters":["People2",7,0,2,"古怪老周"]},{"code":401,"indent":1,"parameters":["「你好」？什麼意思？"]},{"code":401,"indent":1,"parameters":["你是來推銷的嗎？我不買！"]},{"code":101,"indent":1,"parameters":["People2",7,0,2,"古怪老周"]},{"code":401,"indent":1,"parameters":["上次有個人來推銷長生不老藥，"]},{"code":401,"indent":1,"parameters":["我買了三瓶，"]},{"code":401,"indent":1,"parameters":["結果只是加了糖的井水！"]},{"code":101,"indent":1,"parameters":["People2",7,0,2,"古怪老周"]},{"code":401,"indent":1,"parameters":["......雖然味道還不錯就是了。"]},{"code":401,"indent":1,"parameters":["要不你也來一口？我還剩半瓶。"]},{"code":119,"indent":1,"parameters":["選單"]},{"code":402,"indent":0,"parameters":[1,"隔壁很吵嗎？"]},{"code":101,"indent":1,"parameters":["People2",7,0,2,"古怪老周"]},{"code":401,"indent":1,"parameters":["別提了！！你知道隔壁那對夫妻嗎？"]},{"code":401,"indent":1,"parameters":["他們養了一大堆貓！"]},{"code":401,"indent":1,"parameters":["每天晚上那個叫聲——"]},{"code":101,"indent":1,"parameters":["People2",7,0,2,"古怪老周"]},{"code":401,"indent":1,"parameters":["喵嗚～～～喵嗚嗚嗚～～～"]},{"code":401,"indent":1,"parameters":["吵得我整晚睡不著！"]},{"code":401,"indent":1,"parameters":["我都敲門投訴好幾次了！"]},{"code":101,"indent":1,"parameters":["People2",7,0,2,"古怪老周"]},{"code":401,"indent":1,"parameters":["他們居然跟我說家裡沒有貓！？"]},{"code":401,"indent":1,"parameters":["沒有貓怎麼會有貓叫聲！？"]},{"code":401,"indent":1,"parameters":["難道是鬧鬼嗎！？那更恐怖了吧！"]},{"code":101,"indent":1,"parameters":["People2",7,0,2,"古怪老周"]},{"code":401,"indent":1,"parameters":["......不過說實話，"]},{"code":401,"indent":1,"parameters":["那個叫聲有時候聽起來還挺有節奏感的。"]},{"code":401,"indent":1,"parameters":["像是某種......奇怪的歌唱練習？"]},{"code":401,"indent":1,"parameters":["算了我不想深究了。"]},{"code":119,"indent":1,"parameters":["選單"]},{"code":402,"indent":0,"parameters":[2,"告辭"]},{"code":101,"indent":1,"parameters":["People2",7,0,2,"古怪老周"]},{"code":401,"indent":1,"parameters":["嗯，走吧走吧。"]},{"code":401,"indent":1,"parameters":["把門帶好，別讓貓跑進來。"]},{"code":401,"indent":1,"parameters":["......什麼？外面也沒有貓？"]},{"code":401,"indent":1,"parameters":["那到底是什麼在叫啊！？"]},{"code":101,"indent":1,"parameters":["People2",7,0,2,"古怪老周"]},{"code":401,"indent":1,"parameters":["算了，我不想知道了。"]},{"code":401,"indent":1,"parameters":["世界上有很多事情不知道比較幸福。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":8,"y":5}]}