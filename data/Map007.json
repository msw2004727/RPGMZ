witchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"!Flame","direction":6,"pattern":1,"characterIndex":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["火盆裡的炭燒得不急不躁，像老周說故事的節奏。"]},{"code":401,"indent":0,"parameters":["你小時候總覺得這裡像藏寶洞，長大後才明白，藏的多半是村子的舊日子。"]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":true}],"x":7,"y":2},{"id":2,"name":"EV002","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":250,"indent":0,"parameters":[{"name":"Move1","volume":90,"pitch":100,"pan":0}]},{"code":201,"indent":0,"parameters":[0,1,6,23,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":1,"walkAnime":true}],"x":8,"y":11},{"id":3,"name":"老周","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People2","direction":2,"pattern":1,"characterIndex":0},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老周"]},{"code":401,"indent":1,"parameters":["老周正對著一堆舊零件發呆。"]},{"code":401,"indent":1,"parameters":["你很難分清他是在整理寶貝，還是在跟雜物談心。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老周"]},{"code":401,"indent":1,"parameters":["你一進門，老周就把一塊舊木牌拍了拍。"]},{"code":401,"indent":1,"parameters":["那神情像在介紹一柄絕世神兵。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老周"]},{"code":401,"indent":1,"parameters":["老周眯眼看你，先笑了一聲。"]},{"code":401,"indent":1,"parameters":["大概又想起你小時候把他那堆破木頭叫成「廢鐵魔窟」。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["老周_選單"]},{"code":102,"indent":0,"parameters":[["問你在忙啥","說說鄰居","翻我黑歷史","問村裡最近","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問你在忙啥"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老周"]},{"code":401,"indent":1,"parameters":["我在整理東西？你錯了，我是在替這些老傢伙安排晚年。"]},{"code":401,"indent":1,"parameters":["別看它們破，哪塊木牌、哪只舊燈、哪截鐵件沒故事？"]},{"code":401,"indent":1,"parameters":["在我眼裡，半個村的舊日子都堆在這屋裡。"]},{"code":119,"indent":1,"parameters":["老周_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老周"]},{"code":401,"indent":1,"parameters":["阿平修新東西，我收舊東西；韓村長記規矩，我記往事。"]},{"code":401,"indent":1,"parameters":["阿青管現在村口誰進誰出，我則知道十年前誰半夜翻過哪道牆。"]},{"code":401,"indent":1,"parameters":["你們年輕人愛往前衝，可一個村子真能站穩，靠的是有人肯把過去留住。"]},{"code":119,"indent":1,"parameters":["老周_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老周"]},{"code":401,"indent":1,"parameters":["你小時候把一截破木頭撿來，說那是上古神劍殘骸。"]},{"code":401,"indent":1,"parameters":["我順著你胡扯兩句，你當場就想拿去號令群雄。"]},{"code":401,"indent":1,"parameters":["結果那截木頭其實是阿強家掉的門栓，我笑了你三天。"]},{"code":119,"indent":1,"parameters":["老周_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老周"]},{"code":401,"indent":1,"parameters":["最近老有人問東邊舊路以前是做什麼用的，這問題一聽就不單純。"]},{"code":401,"indent":1,"parameters":["真正只是路過的人，頂多問怎麼走；會追問舊事的，通常另有盤算。"]},{"code":401,"indent":1,"parameters":["你要真碰上這種人，別急著跟他比嘴，先記住他到底在意什麼。"]},{"code":119,"indent":1,"parameters":["老周_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老周"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":8,"y":5}]}