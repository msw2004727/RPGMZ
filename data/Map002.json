de":401,"indent":1,"parameters":["二十年前我還是個走江湖的武者，"]},{"code":401,"indent":1,"parameters":["後來受了傷，就在這裡落腳開了酒館。"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老闆"]},{"code":401,"indent":1,"parameters":["別看這地方不大，"]},{"code":401,"indent":1,"parameters":["南來北往的江湖人都會來歇歇腳。"]},{"code":401,"indent":1,"parameters":["有時候聽客人們聊天，"]},{"code":401,"indent":1,"parameters":["比起當年闖蕩江湖還精彩呢！"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老闆"]},{"code":401,"indent":1,"parameters":["不過做這行最重要的就是——嘴巴要緊。"]},{"code":401,"indent":1,"parameters":["在我這裡聽到的事，出了門可就別提了。"]},{"code":401,"indent":1,"parameters":["這是江湖規矩，你懂的。"]},{"code":119,"indent":1,"parameters":["選單"]},{"code":402,"indent":0,"parameters":[1,"有什麼推薦的酒？"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老闆"]},{"code":401,"indent":1,"parameters":["說到酒，那你可算問對人了！"]},{"code":401,"indent":1,"parameters":["我們這兒有三樣招牌："]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老闆"]},{"code":401,"indent":1,"parameters":["第一是「烈陽燒」，"]},{"code":401,"indent":1,"parameters":["喝一口從喉嚨暖到腳底板，"]},{"code":401,"indent":1,"parameters":["是武者們練功後的最愛。"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老闆"]},{"code":401,"indent":1,"parameters":["第二是「碧螺春釀」，口感清甜回甘，"]},{"code":401,"indent":1,"parameters":["就算不勝酒力的人也能來上一杯，"]},{"code":401,"indent":1,"parameters":["姑娘們特別喜歡。"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老闆"]},{"code":401,"indent":1,"parameters":["第三嘛......是我的私藏「醉仙釀」。"]},{"code":401,"indent":1,"parameters":["用深山裡採來的百年靈芝和雪蓮花釀製，"]},{"code":401,"indent":1,"parameters":["喝了據說能提神醒腦、恢復元氣。"]},{"code":401,"indent":1,"parameters":["不過這酒可不便宜，一壺要五百金幣呢！哈哈！"]},{"code":119,"indent":1,"parameters":["選單"]},{"code":402,"indent":0,"parameters":[2,"這附近有什麼消息？"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老闆"]},{"code":401,"indent":1,"parameters":["消息啊......最近確實不太平。"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老闆"]},{"code":401,"indent":1,"parameters":["聽說北方的黑風寨"]},{"code":401,"indent":1,"parameters":["被一個神秘人物給剿了，"]},{"code":401,"indent":1,"parameters":["一夜之間整個山寨化為灰燼，"]},{"code":401,"indent":1,"parameters":["連寨主都不知所蹤。"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老闆"]},{"code":401,"indent":1,"parameters":["還有人說東邊的幽暗密林裡"]},{"code":401,"indent":1,"parameters":["出現了從沒見過的魔物，"]},{"code":401,"indent":1,"parameters":["好幾個老練的冒險者進去"]},{"code":401,"indent":1,"parameters":["就再也沒回來過。"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老闆"]},{"code":401,"indent":1,"parameters":["要我說啊，出門在外千萬小心。"]},{"code":401,"indent":1,"parameters":["這世道......可不比從前了。"]},{"code":401,"indent":1,"parameters":["要是你準備往那邊去，多備些藥品吧。"]},{"code":119,"indent":1,"parameters":["選單"]},{"code":402,"indent":0,"parameters":[3,"沒事，告辭"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老闆"]},{"code":401,"indent":1,"parameters":["好的，慢走啊！"]},{"code":401,"indent":1,"parameters":["下次再來喝一杯！"]},{"code":401,"indent":1,"parameters":["「醉仙樓」隨時歡迎你。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":5,"y":5},{"id":6,"name":"醉客","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"People2","direction":8,"pattern":1,"characterIndex":3},"list":[{"code":101,"indent":0,"parameters":["People2",3,0,2,"醉客"]},{"code":401,"indent":0,"parameters":["嗝～老板再來一壺好酒！"]},{"code":401,"indent":0,"parameters":["......你說什麼？我才沒有喝醉！"]},{"code":401,"indent":0,"parameters":["這才第三壺而已！"]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"