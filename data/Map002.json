ers":[["聊聊酒館的事","有什麼推薦的酒？","這附近有什麼消息？","沒事，告辭"],3,0,2,0]},{"code":402,"indent":0,"parameters":[0,"聊聊酒館的事"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["這間「醉仙樓」可是我一手打拼出來的！"]},{"code":401,"indent":1,"parameters":["二十年前我還是個走江湖的武者——"]},{"code":401,"indent":1,"parameters":["外號「疾風趙」！聽過沒？"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["......沒聽過也正常，"]},{"code":401,"indent":1,"parameters":["因為我出道第二年就閃到腰退休了。"]},{"code":401,"indent":1,"parameters":["人生嘛，計劃趕不上變化！"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["不過開酒館也不錯啦，"]},{"code":401,"indent":1,"parameters":["至少不用每天擔心被人追殺。"]},{"code":401,"indent":1,"parameters":["只要擔心客人喝醉打架就行了，嘿嘿。"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["對了，在我這裡聽到的消息，"]},{"code":401,"indent":1,"parameters":["出了門可就別亂講！"]},{"code":401,"indent":1,"parameters":["上次有人出去亂傳，結果——"]},{"code":401,"indent":1,"parameters":["......算了不說了，總之你懂的。"]},{"code":119,"indent":1,"parameters":["選單"]},{"code":402,"indent":0,"parameters":[1,"有什麼推薦的酒？"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["說到酒你可算問對人了！"]},{"code":401,"indent":1,"parameters":["第一道「烈陽燒」——"]},{"code":401,"indent":1,"parameters":["喝一口你會覺得有人在你嘴裡放了一把火！"]},{"code":401,"indent":1,"parameters":["武者們的最愛，但新手建議先準備好水。"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["第二道「碧螺春釀」——清甜順口，"]},{"code":401,"indent":1,"parameters":["號稱喝十杯也不會醉！"]},{"code":401,"indent":1,"parameters":["......好吧，上次說這話的人"]},{"code":401,"indent":1,"parameters":["第二天趴在桌上起不來了。"]},{"code":101,"indent":1,"parameters":["People2",0,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["第三道嘛......是我的私藏「醉仙釀」！"]},{"code":401,"indent":1,"parameters":["據說喝了能打通任督二脈！"]},{"code":401,"indent":1,"parameters":["五百金一壺！"]},{"code":401,"indent":1,"parameters":[