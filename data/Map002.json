味。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People1",6,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["來了啊，小時候喝米酒被辣到直跳腳的那位少俠。"]},{"code":401,"indent":1,"parameters":["今天總算長得像個能坐桌的人了。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[12,"$gameSwitches.value(2) && !$gameSwitches.value(3)"]},{"code":101,"indent":1,"parameters":["People1",6,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["對了，你在問那個生面孔對吧？"]},{"code":401,"indent":1,"parameters":["昨晚那人進門只問東邊舊路怎麼走，連酒都沒碰一下。"]},{"code":401,"indent":1,"parameters":["我開酒館這麼多年，越不肯碰酒的人，越像肚子裡藏著事。"]},{"code":355,"indent":1,"parameters":["$gameSwitches.setValue(3,true);$gameSwitches.setValue(7,$gameSwitches.value(3)&&$gameSwitches.value(4)&&$gameSwitches.value(5));"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["老趙_選單"]},{"code":102,"indent":0,"parameters":[["問酒館近況","說說鄰居","翻我黑歷史","問最近風聲","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問酒館近況"]},{"code":101,"indent":1,"parameters":["People1",6,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["最近酒館倒是比以前熱鬧。"]},{"code":401,"indent":1,"parameters":["阿彪一下工就來灌兩口，老丁一下雨就來裝醉，阿蘭嘴上說只是歇腳，坐下就能聊半個時辰。"]},{"code":401,"indent":1,"parameters":["真要論穩村之功，我這酒館至少值半面錦旗。"]},{"code":119,"indent":1,"parameters":["老趙_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People1",6,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["阿梅那邊常送剩菜給我下酒，我這邊也常替她留半壺熱湯。"]},{"code":401,"indent":1,"parameters":["秋娘賣醒酒藥賣得像割我肉，偏偏老丁又離不開。"]},{"code":401,"indent":1,"parameters":["老王那鐵舖一開工，全村都知道他今天心情怎麼樣。"]},{"code":119,"indent":1,"parameters":["老趙_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People1",6,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["你小時候偷溜進來，想學大人豪飲江湖。"]},{"code":401,"indent":1,"parameters":["結果喝的是我摻了水的米酒，你還被辣到原地跳「醉燕翻身」。"]},{"code":401,"indent":1,"parameters":["從那天起，我就知道你有熱血，也有一點點不長記性。"]},{"code":119,"indent":1,"parameters":["老趙_選單"]},{"code":402,"indent":0,"parameters":[3,"問最近風聲"]},{"code":101,"indent":1,"parameters":["People1",6,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["最近啊，大家嘴上都在講東邊舊路。"]},{"code":401,"indent":1,"parameters":["阿光喊得像要去斬妖除魔，阿蛇則說那邊八成有商機。"]},{"code":401,"indent":1,"parameters":["我看哪，真相還沒冒頭，這群人就先把故事說成三十個版本了。"]},{"code":119,"indent":1,"parameters":["老趙_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People1",6,0,2,"老趙"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":5,"y":5},{"id":6,"name":"酒糟老丁","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People4","direction":8,"pattern":1,"characterIndex":4},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People4",4,0,2,"酒糟老丁"]},{"code":401,"indent":1,"parameters":["欸？是你啊。"]},{"code":401,"indent":1,"parameters":["別扶我，我沒醉，我只是江湖在晃。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People4",4,0,2,"酒糟老丁"]},{"code":401,"indent":1,"parameters":["我眼睛沒花吧？"]},{"code":401,"indent":1,"parameters":["你小時候搶我花生那個娃，現在都這麼高了？"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People4",4,0,2,"酒糟老丁"]},{"code":401,"indent":1,"parameters":["你來得正好。"]},{"code":401,"indent":1,"parameters":["我正準備施展「千杯不倒訣」，就差一個見證人。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["酒糟老丁_選單"]},{"code":102,"indent":0,"parameters":[["問你在忙啥","說說鄰居","翻我黑歷史","問村裡最近","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問你在忙啥"]},{"code":101,"indent":1,"parameters":["People4",4,0,2,"酒糟老丁"]},{"code":401,"indent":1,"parameters":["我在忙什麼？"]},{"code":401,"indent":1,"parameters":["我在忙著把今天的煩悶泡進酒裡，這可是高深修行。"]},{"code":401,"indent":1,"parameters":["白天守穀倉，晚上守酒杯，這日子也算刀槍不入。"]},{"code":119,"indent":1,"parameters":["酒糟老丁_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People4",4,0,2,"酒糟老丁"]},{"code":401,"indent":1,"parameters":["阿平修屋頂是一把好手，可喝起酒來比我還能扯。"]},{"code":401,"indent":1,"parameters":["阿蛇欠了我半包花生，到現在還拿「周轉靈活」當藉口。"]},{"code":401,"indent":1,"parameters":["老趙嘴上兇，真見我醉過頭，還是會多塞我一碗熱湯。"]},{"code":119,"indent":1,"parameters":["酒糟老丁_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People4",4,0,2,"酒糟老丁"]},{"code":401,"indent":1,"parameters":["你小時候最愛偷我桌上的花生。"]},{"code":401,"indent":1,"parameters":["偷就算了，還邊跑邊喊自己在練「流星摘星手」。"]},{"code":401,"indent":1,"parameters":["我看那不是摘星手，是嘴饞手。"]},{"code":119,"indent":1,"parameters":["酒糟老丁_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People4",4,0,2,"酒糟老丁"]},{"code":401,"indent":1,"parameters":["最近村裡最熱的不是酒，是東邊舊路那股怪風聲。"]},{"code":401,"indent":1,"parameters":["可我跟你說，真正可怕的從來不是風，是風把全村嘴巴都吹開。"]},{"code":401,"indent":1,"parameters":["你看我，明明坐著，耳朵卻已經累一天了。"]},{"code":119,"indent":1,"parameters":["酒糟老丁_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People4",4,0,2,"酒糟老丁"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":10,"y":8},{"id":7,"name":"肉鋪阿彪","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People2","direction":4,"pattern":1,"characterIndex":4},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"肉鋪阿彪"]},{"code":401,"indent":1,"parameters":["喲！這不是咱村的小子嗎？"]},{"code":401,"indent":1,"parameters":["你現在看起來終於有點能扛肉的樣子了。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"肉鋪阿彪"]},{"code":401,"indent":1,"parameters":["我剛從肉鋪收工。"]},{"code":401,"indent":1,"parameters":["老趙一喊，我就來這裡補一碗酒，這叫英雄的日常保養。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"肉鋪阿彪"]},{"code":401,"indent":1,"parameters":["你小時候想舉我的剁骨刀，"]},{"code":401,"indent":1,"parameters":["結果刀沒舉起來，自己先一屁股坐地上。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["肉鋪阿彪_選單"]},{"code":102,"indent":0,"parameters":[["問你在忙啥","說說鄰居","翻我黑歷史","問村裡最近","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問你在忙啥"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"肉鋪阿彪"]},{"code":401,"indent":1,"parameters":["我白天在肉鋪砍肉，晚上在這裡喝兩口，這叫剛柔並濟。"]},{"code":401,"indent":1,"parameters":["阿光老說我刀重氣猛，我說我那是對食材的尊重。"]},{"code":401,"indent":1,"parameters":["真英雄不只會揮刀，還要會吃。"]},{"code":119,"indent":1,"parameters":["肉鋪阿彪_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"肉鋪阿彪"]},{"code":401,"indent":1,"parameters":["老王磨刀是本村第一，秋娘貼藥也是本村第一，阿光喊口號更是天下第一。"]},{"code":401,"indent":1,"parameters":["我若手臂酸了就找秋娘，刀鈍了就找老王，耳朵吵了就躲阿光遠點。"]},{"code":401,"indent":1,"parameters":["各司其職，這才像個村子。"]},{"code":119,"indent":1,"parameters":["肉鋪阿彪_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"肉鋪阿彪"]},{"code":401,"indent":1,"parameters":["你小時候非要舉我的剁骨刀，說要演「一刀平山」。"]},{"code":401,"indent":1,"parameters":["結果刀沒離地，你自己先坐地上，還硬說那是蹲馬步。"]},{"code":401,"indent":1,"parameters":["我差點笑到把砧板拍裂。"]},{"code":119,"indent":1,"parameters":["肉鋪阿彪_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"肉鋪阿彪"]},{"code":401,"indent":1,"parameters":["最近來村裡的人多了一點，肉也跟著賣得快。"]},{"code":401,"indent":1,"parameters":["但真要說怪，還是東邊那條路讓人心裡不踏實。"]},{"code":401,"indent":1,"parameters":["有些人走路像趕路，有些人走路像怕被誰看見，這兩種味道不一樣。"]},{"code":119,"indent":1,"parameters":["肉鋪阿彪_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"肉鋪阿彪"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":13,"y":6},{"id":8,"name":"跑腿阿順","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People_ex1","direction":8,"pattern":1,"characterIndex":3},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"跑腿阿順"]},{"code":401,"indent":1,"parameters":["又見面了。"]},{"code":401,"indent":1,"parameters":["我剛替韓村長送完信，再晚一步就要被阿安追著補章。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"跑腿阿順"]},{"code":401,"indent":1,"parameters":["你還記得嗎？"]},{"code":401,"indent":1,"parameters":["小時候你塞給我一張假手令，叫我替你傳去阿梅那邊免打雜。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"跑腿阿順"]},{"code":401,"indent":1,"parameters":["我這雙腿啊，跑遍全村。"]},{"code":401,"indent":1,"parameters":["真要說哪裡有風吹草動，我大概比阿青還早半步知道。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["跑腿阿順_選單"]},{"code":102,"indent":0,"parameters":[["問你在忙啥","說說鄰居","翻我黑歷史","問村裡最近","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問你在忙啥"]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"跑腿阿順"]},{"code":401,"indent":1,"parameters":["我就是跑腿送信的。"]},{"code":401,"indent":1,"parameters":["韓村長要通知、阿安要回條、阿青要口信，半村事情都得從我腳底跑過。"]},{"code":401,"indent":1,"parameters":["真要比江湖身法，我這雙腿在村內算得上前排。"]},{"code":119,"indent":1,"parameters":["跑腿阿順_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"跑腿阿順"]},{"code":401,"indent":1,"parameters":["阿安做事最細，阿青做事最快，韓村長看得最遠。"]},{"code":401,"indent":1,"parameters":["我夾在中間，像一張會喘氣的傳令紙。"]},{"code":401,"indent":1,"parameters":["但也因為這樣，誰跟誰最近鬧彆扭，我通常比當事人早知道。"]},{"code":119,"indent":1,"parameters":["跑腿阿順_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"跑腿阿順"]},{"code":401,"indent":1,"parameters":["你小時候塞給我一張假手令，叫我替你交去阿梅那邊免打雜。"]},{"code":401,"indent":1,"parameters":["結果印泥是你拿甜菜汁抹的，紙還沒送到就先糊了。"]},{"code":401,"indent":1,"parameters":["我那時就懂，真正的少俠首先要學會別騙熟人。"]},{"code":119,"indent":1,"parameters":["跑腿阿順_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"跑腿阿順"]},{"code":401,"indent":1,"parameters":["最近村裡往外寄的信變多，尤其跟東邊舊路有關的詢問。"]},{"code":401,"indent":1,"parameters":["人一緊張，就愛寫信、貼告示、互相打聽。"]},{"code":401,"indent":1,"parameters":["但我覺得最有用的，還是有人肯出去把話問清。"]},{"code":119,"indent":1,"parameters":["跑腿阿順_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"跑腿阿順"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":12,"y":8},{"id":9,"name":"染布阿蘭","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People1","direction":2,"pattern":1,"characterIndex":5},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People1",5,0,2,"染布阿蘭"]},{"code":401,"indent":1,"parameters":["看什麼？"]},{"code":401,"indent":1,"parameters":["我只是進來坐會兒，不是進來選夫婿。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People1",5,0,2,"染布阿蘭"]},{"code":401,"indent":1,"parameters":["你小時候把山莓汁潑我布上，"]},{"code":401,"indent":1,"parameters":["還硬說那叫「魔教血染紋」，我到現在都想笑。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People1",5,0,2,"染布阿蘭"]},{"code":401,"indent":1,"parameters":["小禾說你最近變穩重了。"]},{"code":401,"indent":1,"parameters":["我看還早，你站那樣就像又要惹事。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["染布阿蘭_選單"]},{"code":102,"indent":0,"parameters":[["問你在忙啥","說說鄰居","翻我黑歷史","問村裡最近","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問你在忙啥"]},{"code":101,"indent":1,"parameters":["People1",5,0,2,"染布阿蘭"]},{"code":401,"indent":1,"parameters":["我白天染布，傍晚來這裡歇腿。"]},{"code":401,"indent":1,"parameters":["別看我坐著，腦子裡還在算哪塊布該配哪條邊。"]},{"code":401,"indent":1,"parameters":["江湖人挑劍，我挑顏色，失手一樣丟臉。"]},{"code":119,"indent":1,"parameters":["染布阿蘭_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People1",5,0,2,"染布阿蘭"]},{"code":401,"indent":1,"parameters":["小禾縫得細，小桃嘴甜，阿梅心最軟。"]},{"code":401,"indent":1,"parameters":["她們三個站一起，能把整條街的日子縫得服服貼貼。"]},{"code":401,"indent":1,"parameters":["我啊，就負責把顏色弄漂亮，省得你們這群人穿得像土裡剛挖出來。"]},{"code":119,"indent":1,"parameters":["染布阿蘭_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People1",5,0,2,"染布阿蘭"]},{"code":401,"indent":1,"parameters":["你小時候把山莓汁潑我布上，還硬說那叫「魔教血染紋」。"]},{"code":401,"indent":1,"parameters":["我本來想罵你，結果你講得太認真，我差點笑得拿不穩盆。"]},{"code":401,"indent":1,"parameters":["所以我現在看你板著臉，就知道你八成又要講幹話。"]},{"code":119,"indent":1,"parameters":["染布阿蘭_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People1",5,0,2,"染布阿蘭"]},{"code":401,"indent":1,"parameters":["最近外頭風聲多，連布價都跟著浮。"]},{"code":401,"indent":1,"parameters":["東邊路上灰一大，衣料就容易髒，生意算是跟著緊張一起來。"]},{"code":401,"indent":1,"parameters":["不過再亂的風，也吹不散這村裡的人情味。"]},{"code":119,"indent":1,"parameters":["染布阿蘭_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People1",5,0,2,"染布阿蘭"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code"