ers":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["唷，咱村那個從小拿木劍亂砍空氣的傢伙來了。"]},{"code":401,"indent":1,"parameters":["現在總算像個能買真貨的人。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["你一進門，鐵都像熱得更快。"]},{"code":401,"indent":1,"parameters":["八成是因為你小時候在我爐邊挨過太多罵。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["別碰那錘子。"]},{"code":401,"indent":1,"parameters":["你六歲時碰過一次，拇指腫得像顆小饅頭，哭聲整條街都聽見。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[12,"$gameSwitches.value(2) && !$gameSwitches.value(4)"]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["你問那個怪人？有。"]},{"code":401,"indent":1,"parameters":["前天有人拿刀來磨，刀上是泥和草汁，不像正常砍柴。"]},{"code":401,"indent":1,"parameters":["我打鐵一輩子，工具一落在手裡，像不像在偷偷辦事，我一摸就知道。"]},{"code":355,"indent":1,"parameters":["$gameSwitches.setValue(4,true);$gameSwitches.setValue(7,$gameSwitches.value(3)&&$gameSwitches.value(4)&&$gameSwitches.value(5));"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["鐵頭老王_選單"]},{"code":102,"indent":0,"parameters":[["看貨","問鐵舖近況","說說鄰居","翻我黑歷史","問村裡最近","先走"],5,0,2,0]},{"code":402,"indent":0,"parameters":[0,"看貨"]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["行，眼睛放亮點。"]},{"code":401,"indent":1,"parameters":["這裡沒有花架子，只有能上手的真傢伙。"]},{"code":302,"indent":1,"parameters":[1,1,0,0]},{"code":605,"indent":1,"parameters":[1,43,0,0]},{"code":605,"indent":1,"parameters":[1,7,0,0]},{"code":605,"indent":1,"parameters":[1,13,0,0]},{"code":605,"indent":1,"parameters":[1,25,0,0]},{"code":605,"indent":1,"parameters":[1,37,0,0]},{"code":605,"indent":1,"parameters":[2,3,0,0]},{"code":605,"indent":1,"parameters":[2,27,0,0]},{"code":605,"indent":1,"parameters":[2,46,0,0]},{"code":605,"indent":1,"parameters":[2,47,0,0]},{"code":605,"indent":1,"parameters":[2,73,0,0]},{"code":605,"indent":1,"parameters":[2,75,0,0]},{"code":119,"indent":1,"parameters":["鐵頭老王_選單"]},{"code":119,"indent":1,"parameters":["鐵頭老王_選單"]},{"code":402,"indent":0,"parameters":[1,"問鐵舖近況"]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["最近來磨刀、修鋤、補鍋的人一堆。"]},{"code":401,"indent":1,"parameters":["別看只是小村，誰家少了好工具，日子立刻就卡住。"]},{"code":401,"indent":1,"parameters":["我這鐵舖不只賣東西，也是在替全村撐骨頭。"]},{"code":119,"indent":1,"parameters":["鐵頭老王_選單"]},{"code":402,"indent":0,"parameters":[2,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["阿彪那把剁骨刀三天兩頭來磨，鈍得比他腦袋還快。"]},{"code":401,"indent":1,"parameters":["阿平借過我的刨刀，回來還磨得比借走前更亮，這人懂規矩。"]},{"code":401,"indent":1,"parameters":["阿光想要威風，我勸他先把甲穿穩，再談什麼正義出鞘。"]},{"code":119,"indent":1,"parameters":["鐵頭老王_選單"]},{"code":402,"indent":0,"parameters":[3,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["你六歲那年偷摸我鐵錘，想學我「一擊定乾坤」。"]},{"code":401,"indent":1,"parameters":["結果鐵還沒碰，先把自己手砸腫，哭得比火爐還響。"]},{"code":401,"indent":1,"parameters":["所以我現在看你靠近鐵器，第一反應還是先護著工具。"]},{"code":119,"indent":1,"parameters":["鐵頭老王_選單"]},{"code":402,"indent":0,"parameters":[4,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["最近最怪的是，有人拿來磨的刀上不是血，是濕泥和草汁。"]},{"code":401,"indent":1,"parameters":["正常砍柴、下田、剁肉，味道我一聞就分得出。"]},{"code":401,"indent":1,"parameters":["這回那股氣味，像是有人在山路裡挖東西，又怕別人知道。"]},{"code":119,"indent":1,"parameters":["鐵頭老王_選單"]},{"code":402,"indent":0,"parameters":[5,"先走"]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"i