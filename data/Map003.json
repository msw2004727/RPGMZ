{"id":3,"name":"鐵頭老王","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People1","direction":2,"pattern":1,"characterIndex":2},"list":[{"code":101,"indent":0,"parameters":["People1",2,0,2,"鐵頭老王"]},{"code":401,"indent":0,"parameters":["唷！又來一個看起來弱不禁風的傢伙！"]},{"code":401,"indent":0,"parameters":["別怕別怕，老王我打的武器保證品質！"]},{"code":401,"indent":0,"parameters":["讓你從菜雞變成......稍微沒那麼菜的雞！哈哈！"]},{"code":118,"indent":0,"parameters":["選單"]},{"code":102,"indent":0,"parameters":[["我要買裝備！","你這店怎麼回事？","算了告辭"],2,0,2,0]},{"code":402,"indent":0,"parameters":[0,"我要買裝備！"]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["好眼光！這些可都是我一鐵錘一鐵錘敲出來的！"]},{"code":401,"indent":1,"parameters":["每一件都灌注了我的血汗......"]},{"code":401,"indent":1,"parameters":["還有偶爾砸到手指的眼淚！看看吧！"]},{"code":302,"indent":1,"parameters":[1,1,0,0]},{"code":605,"indent":1,"parameters":[1,43,0,0]},{"code":605,"indent":1,"parameters":[1,7,0,0]},{"code":605,"indent":1,"parameters":[1,13,0,0]},{"code":605,"indent":1,"parameters":[1,25,0,0]},{"code":605,"indent":1,"parameters":[1,37,0,0]},{"code":605,"indent":1,"parameters":[2,3,0,0]},{"code":605,"indent":1,"parameters":[2,27,0,0]},{"code":605,"indent":1,"parameters":[2,46,0,0]},{"code":605,"indent":1,"parameters":[2,47,0,0]},{"code":605,"indent":1,"parameters":[2,73,0,0]},{"code":605,"indent":1,"parameters":[2,75,0,0]},{"code":119,"indent":1,"parameters":["選單"]},{"code":402,"indent":0,"parameters":[1,"你這店怎麼回事？"]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["怎麼回事？什麼怎麼回事？"]},{"code":401,"indent":1,"parameters":["這可是村子裡唯一的武器店！"]},{"code":401,"indent":1,"parameters":["你不在我這買，難道要赤手空拳去打怪？"]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["我跟你說，上禮拜有個年輕人嫌我東西貴，"]},{"code":401,"indent":1,"parameters":["覺得靠拳頭就夠了......"]},{"code":401,"indent":1,"parameters":["結果當天晚上就被史萊姆追了三條街！"]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["後來哭著跑回來買了把短劍，"]},{"code":401,"indent":1,"parameters":["還多買了一面盾！哈哈哈哈！"]},{"code":119,"indent":1,"parameters":["選單"]},{"code":402,"indent":0,"parameters":[2,"算了告辭"]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"鐵頭老王"]},{"code":401,"indent":1,"parameters":["哼，走吧走吧！"]},{"code":401,"indent":1,"parameters":["等你在外面被怪物追著跑的時候，"]},{"code":401,"indent":1,"parameters":["記得跑回來找老王——記得帶錢！哈哈！"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":6,"y":4},
