},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People2",3,0,2,"林二嫂"]},{"code":401,"indent":1,"parameters":["小桃說阿強最近又偷藏零嘴，阿梅則笑得像早就知道。"]},{"code":401,"indent":1,"parameters":["秋娘看起來兇，可誰家廚房割了手，第一個跑去的還是她那裡。"]},{"code":401,"indent":1,"parameters":["這村子表面吵，骨子裡倒是互相顧著。"]},{"code":119,"indent":1,"parameters":["林二嫂_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People2",3,0,2,"林二嫂"]},{"code":401,"indent":1,"parameters":["你小時候借我家鐮刀擺架勢，說自己在練「割月刀」。"]},{"code":401,"indent":1,"parameters":["結果草沒割整齊，反把自己袖口拉出一道大口子。"]},{"code":401,"indent":1,"parameters":["小禾替你縫那回，笑到手都在抖。"]},{"code":119,"indent":1,"parameters":["林二嫂_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People2",3,0,2,"林二嫂"]},{"code":401,"indent":1,"parameters":["最近大家都在談東邊舊路，弄得男人一個個都想裝膽大。"]},{"code":401,"indent":1,"parameters":["我看哪，先把家裡鍋碗顧好，再談什麼江湖風浪。"]},{"code":401,"indent":1,"parameters":["人能好好回家吃飯，已經勝過半本英雄譜。"]},{"code":119,"indent":1,"parameters":["林二嫂_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People2",3,0,2,"林二嫂"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":10,"y":7},{"id":5,"name":"小春","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People1","direction":2,"pattern":1,"characterIndex":3},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小春"]},{"code":401,"indent":1,"parameters":["你來啦？"]},{"code":401,"indent":1,"parameters":["我是在等老王幫我找把順手的小刀，不是來看你發呆的。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小春"]},{"code":401,"indent":1,"parameters":["你小時候削木笛，削到最後吹出來像雞被踩到。"]},{"code":401,"indent":1,"parameters":["還硬說那是「悲風哨」。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小春"]},{"code":401,"indent":1,"parameters":["阿旺說你最近很像樣。"]},{"code":401,"indent":1,"parameters":["我看是比以前像樣一點，但離大俠還早。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["小春_選單"]},{"code":102,"indent":0,"parameters":[["問你在忙啥","說說鄰居","翻我黑歷史","問村裡最近","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問你在忙啥"]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小春"]},{"code":401,"indent":1,"parameters":["我想買把順手的小刀，剪線削木都能用。"]},{"code":401,"indent":1,"parameters":["別小看這種小東西，真正過日子的人都知道它有多重要。"]},{"code":401,"indent":1,"parameters":["老王的嘴雖硬，手上的貨倒是沒話說。"]},{"code":119,"indent":1,"parameters":["小春_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小春"]},{"code":401,"indent":1,"parameters":["阿旺最近老說自己在學經營，小禾則說他先學會別偷吃再談。"]},{"code":401,"indent":1,"parameters":["阿平幫我修過窗框，手真穩；阿梅一看到誰皺眉，就知道是不是沒吃飽。"]},{"code":401,"indent":1,"parameters":["在這村裡，想找人幫忙不難，難的是你得先準備被吐槽。"]},{"code":119,"indent":1,"parameters":["小春_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小春"]},{"code":401,"indent":1,"parameters":["你小時候削木笛，削到最後吹出來像雞被踩到。"]},{"code":401,"indent":1,"parameters":["還硬說那是「悲風哨」，專門震懾敵膽。"]},{"code":401,"indent":1,"parameters":["我那時就覺得，你未來不是大俠，就是大笑話。"]},{"code":119,"indent":1,"parameters":["小春_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小春"]},{"code":401,"indent":1,"parameters":["最近村裡人嘴上全是東邊那條路，手上卻還是得照樣做活。"]},{"code":401,"indent":1,"parameters":["這倒也對，天再大，飯還是要吃，窗還是要補。"]},{"code":401,"indent":1,"parameters":["真要有事，等它走到村口再一起上，現在先別自己嚇自己。"]},{"code":119,"indent":1,"parameters":["小春_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小春"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":10,"y":5}]}