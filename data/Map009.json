e":401,"indent":1,"parameters":["好吧其實是看心情營業，但你運氣應該不錯！"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":8,"y":4},{"id":4,"name":"正義騎士 阿光","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"People3","direction":4,"pattern":1,"characterIndex":5},"list":[{"code":101,"indent":0,"parameters":["People3",5,0,2,"正義騎士 阿光"]},{"code":401,"indent":0,"parameters":["我是阿光！立志成為天下第一正義的男人！"]},{"code":401,"indent":0,"parameters":["邪惡在我面前絕對無所遁形！"]},{"code":118,"indent":0,"parameters":["光選單"]},{"code":102,"indent":0,"parameters":[["你在這裡做什麼？","正義是什麼？","告辭"],2,0,2,0]},{"code":402,"indent":0,"parameters":[0,"你在這裡做什麼？"]},{"code":101,"indent":1,"parameters":["People3",5,0,2,"正義騎士 阿光"]},{"code":401,"indent":1,"parameters":["買藥！正義使者也是會受傷的！"]},{"code":401,"indent":1,"parameters":["上次我看到有老奶奶過馬路，"]},{"code":401,"indent":1,"parameters":["正義地衝過去要幫忙——"]},{"code":401,"indent":1,"parameters":["結果被牛車撞飛了。"]},{"code":101,"indent":1,"parameters":["People3",5,0,2,"正義騎士 阿光"]},{"code":401,"indent":1,"parameters":["但是！老奶奶安全了！"]},{"code":401,"indent":1,"parameters":["這就是正義的代價！"]},{"code":401,"indent":1,"parameters":["......雖然老奶奶說她其實不需要幫忙。"]},{"code":119,"indent":1,"parameters":["光選單"]},{"code":402,"indent":0,"parameters":[1,"正義是什麼？"]},{"code":101,"indent":1,"parameters":["People3",5,0,2,"正義騎士 阿光"]},{"code":401,"indent":1,"parameters":["好問題！正義就是——"]},{"code":401,"indent":1,"parameters":["看到壞人要打！看到弱者要幫！"]},{"code":401,"indent":1,"parameters":["看到不公不義要大聲喊出來！"]},{"code":101,"indent":1,"parameters":["People3",5,0,2,"正義騎士 阿光"]},{"code":401,"indent":1,"parameters":["上禮拜我看到旁邊那個傢伙偷蘋果，"]},{"code":401,"indent":1,"parameters":["我正義地大喊「住手」！"]},{"code":401,"indent":1,"parameters":["結果他說那是他自己家的蘋果樹。"]},{"code":401,"indent":1,"parameters":["......正義偶爾也會出差錯的！"]},{"code":119,"indent":1,"parameters":["光選單"]},{"code":402,"indent":0,"parameters":[2,"告辭"]},{"code":101,"indent":1,"parameters":["People3",5,0,2,"正義騎士 阿光"]},{"code":401,"indent":1,"parameters":["去吧！帶著正義前進！"]},{"code":401,"indent":1,"parameters":["如果遇到壞人，喊我的名字！"]},{"code":401,"indent":1,"parameters":["......不過距離太遠的話我可能聽不到就是了。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":6,"y":7},{"id":5,"name":"蛇哥","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"People2","direction":6,"pattern":2,"characterIndex":4},"list":[{"code":101,"indent":0,"parameters":["People2",4,0,2,"蛇哥"]},{"code":401,"indent":0,"parameters":["嘿嘿嘿......兄弟，要不要看點好東西？"]},{"code":401,"indent":0,"parameters":["都是市面上買不到的稀罕貨......"]},{"code":118,"indent":0,"parameters":["蛇選單"]},{"code":102,"indent":0,"parameters":[["什麼好東西？","你看起來不像好人","告辭"],2,0,2,0]},{"code":402,"indent":0,"parameters":[0,"什麼好東西？"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"蛇哥"]},{"code":401,"indent":1,"parameters":["嘿嘿，識貨！"]},{"code":401,"indent":1,"parameters":["我這有偷——呃，「收購」來的情報："]},{"code":401,"indent":1,"parameters":["東邊密林深處有個寶箱，"]},{"code":401,"indent":1,"parameters":["裡面的東西值至少一萬金！"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"蛇哥"]},{"code":401,"indent":1,"parameters":["你問我怎麼不自己去拿？"]},{"code":401,"indent":1,"parameters":["......因為那旁邊有一隻很大的東西。"]},{"code":401,"indent":1,"parameters":["很大、很醜、很會咬人的那種。"]},{"code":401,"indent":1,"parameters":["所以我決定把這個發財機會「讓」給你！"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"蛇哥"]},{"code":401,"indent":1,"parameters":["怎麼樣？只要五百金的情報費！"]},{"code":401,"indent":1,"parameters":["......三百？好吧兩百！一百也行！"]},{"code":401,"indent":1,"parameters":["拜託你買啊我今天還沒開張！"]},{"code":119,"indent":1,"parameters":["蛇選單"]},{"code":402,"indent":0,"parameters":[1,"你看起來不像好人"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"蛇哥"]},{"code":401,"indent":1,"parameters":["不像好人？我很受傷耶！"]},{"code":401,"indent":1,"parameters":["我可是有營業執照的正規商人！"]},{"code":401,"indent":1,"parameters":["......好吧執照是過期的，"]},{"code":401,"indent":1,"parameters":["但至少我「曾經」是合法的！"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"蛇哥"]},{"code":401,"indent":1,"parameters":["你看旁邊那個正義騎士，"]},{"code":401,"indent":1,"parameters":["整天嚷嚷什麼正義正義的，"]},{"code":401,"indent":1,"parameters":["上次還差點把我扭送官府！"]},{"code":401,"indent":1,"parameters":["就因為我在路邊擺攤沒申請......"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"蛇哥"]},{"code":401,"indent":1,"parameters":["這個世界對小商人太不友善了嗚嗚。"]},{"code":119,"indent":1,"parameters":["蛇選單"]},{"code":402,"indent":0,"parameters":[2,"告辭"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"蛇哥"]},{"code":401,"indent":1,"parameters":["走了？真的不買情報？"]},{"code":401,"indent":1,"parameters":["那你至少幫我跟旁邊那個正義狂人說，"]},{"code":401,"indent":1,"parameters":["我不是壞人好嗎！"]},{"code":401,"indent":1,"parameters":["我只是......比較有商業頭腦而已！"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":10,"y":7}]}