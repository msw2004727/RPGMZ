id":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"!Flame","direction":6,"pattern":1,"characterIndex":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["藥爐裡的火候穩得很，連苦香都像有規矩。"]},{"code":401,"indent":0,"parameters":["你小時候嫌這味道像在練毒功，結果秋娘追著你灌下一碗驅寒湯，當場讓你懷疑人生。"]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":true}],"x":7,"y":2},{"id":2,"name":"EV002","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":250,"indent":0,"parameters":[{"name":"Move1","volume":90,"pitch":100,"pan":0}]},{"code":201,"indent":0,"parameters":[0,1,20,15,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":1,"walkAnime":true}],"x":8,"y":11},{"id":3,"name":"秋娘","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People1","direction":2,"pattern":1,"characterIndex":7},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People1",7,0,2,"秋娘"]},{"code":401,"indent":1,"parameters":["秋娘抬眼一瞄，像先在判斷你是來買藥，還是來討罵。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People1",7,0,2,"秋娘"]},{"code":401,"indent":1,"parameters":["秋娘一邊綁藥包，一邊哼了一聲。"]},{"code":401,"indent":1,"parameters":["那聲音比門口招牌還管用，誰都不敢亂摸她的藥櫃。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People1",7,0,2,"秋娘"]},{"code":401,"indent":1,"parameters":["藥鋪裡苦香正濃，秋娘手上的秤桿卻穩得很。"]},{"code":401,"indent":1,"parameters":["你小時候最怕的就是她說「來，先喝一碗」。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[12,"$gameSwitches.value(2) && !$gameSwitches.value(5)"]},{"code":101,"indent":1,"parameters":["People1",7,0,2,"秋娘"]},{"code":401,"indent":1,"parameters":["你是來問那個外地人的吧？我記得。"]},{"code":401,"indent":1,"parameters":["他買了止血草、驅蟲粉和消腫散，問的還不是白天哪條路好走，而是哪條路晚上不容易撞見人。"]},{"code":401,"indent":1,"parameters":["正常旅人怕迷路，他那副樣子比較像怕被熟人看見。"]},{"code":355,"indent":1,"parameters":["$gameSwitches.setValue(5,true);$gameSwitches.setValue(7,$gameSwitches.value(3)&&$gameSwitches.value(4)&&$gameSwitches.value(5));"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["秋娘_選單"]},{"code":102,"indent":0,"parameters":[["買藥","問藥鋪近況","說說鄰居","翻我黑歷史","問最近風聲","先走"],5,0,2,0]},{"code":402,"indent":0,"parameters":[0,"買藥"]},{"code":101,"indent":1,"parameters":["People1",7,0,2,"秋娘"]},{"code":401,"indent":1,"parameters":["買可以，嫌苦不退錢，喝了喊命苦我也不管。"]},{"code":302,"indent":1,"parameters":[0,7,0,0]},{"code":605,"indent":1,"parameters":[0,8,0,0]},{"code":605,"indent":1,"parameters":[0,9,0,0]},{"code":605,"indent":1,"parameters":[0,10,0,0]},{"code":605,"indent":1,"parameters":[0,11,0,0]},{"code":605,"indent":1,"parameters":[0,12,0,0]},{"code":605,"indent":1,"parameters":[0,13,0,0]},{"code":605,"indent":1,"parameters":[0,14,0,0]},{"code":605,"indent":1,"parameters":[0,15,0,0]},{"code":402,"indent":0,"parameters":[1,"問藥鋪近況"]},{"code":101,"indent":1,"parameters":["People1",7,0,2,"秋娘"]},{"code":401,"indent":1,"parameters":["最近驅蟲、止血、扭傷藥都賣得快，像是有人不是上山，就是準備上山。"]},{"code":401,"indent":1,"parameters":["阿梅那邊累著了會來找我，老王手上起泡也得來找我，連阿光巡夜把自己摔疼都還是得來。"]},{"code":401,"indent":1,"parameters":["你別看我嘴毒，這村有幾口氣是我一路罵回來的。"]},{"code":119,"indent":1,"parameters":["秋娘_選單"]},{"code":402,"indent":0,"parameters":[2,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People1",7,0,2,"秋娘"]},{"code":401,"indent":1,"parameters":["阿梅照顧人靠熱湯，我照顧人靠苦藥；老趙負責讓人忘憂，我負責讓人隔天別躺平。"]},{"code":401,"indent":1,"parameters":["阿蛇嘴滑，可送藥罐倒挺穩；阿光喊得大聲，真有人夜裡發燒，他跑得也不慢。"]},{"code":401,"indent":1,"parameters":["咱村這群人，各有各的毛病，也各有各的用處。"]},{"code":119,"indent":1,"parameters":["秋娘_選單"]},{"code":402,"indent":0,"parameters":[3,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People1",7,0,2,"秋娘"]},{"code":401,"indent":1,"parameters":["你小時候最怕喝我煎的藥，端到嘴邊還能先演一套「壯士訣別」。"]},{"code":401,"indent":1,"parameters":["結果每次喝完病真好，你又臭著臉說自己是被苦功逼退邪氣。"]},{"code":401,"indent":1,"parameters":["我看不是邪氣退，是你那點嘴硬終於扛不住藥味。"]},{"code":119,"indent":1,"parameters":["秋娘_選單"]},{"code":402,"indent":0,"parameters":[4,"問最近風聲"]},{"code":101,"indent":1,"parameters":["People1",7,0,2,"秋娘"]},{"code":401,"indent":1,"parameters":["最近談東邊舊路的人多，可真正讓我起疑的，是有人提前來備外傷藥。"]},{"code":401,"indent":1,"parameters":["怕走夜路的人買燈，怕摔的人買膏，怕見血的人才會先來我這裡抓一整包止血散。"]},{"code":401,"indent":1,"parameters":["你若真去查，別只聽話，連別人買了什麼都得記。"]},{"code":119,"indent":1,"parameters":["秋娘_選單"]},{"code":402,"indent":0,"parameters":[5,"先走"]},{"code":101,"indent":1,"parameters":["People1",7,0,2,"秋娘"]},{"code":401,"indent":1,"parameters":["藥買完就走，別擋著我分藥。"]},{"code":401,"indent":1,"parameters":["當然，你若只是想聽我多罵你兩句，也不是不行。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":8,"y":4},{"id":4,"name":"阿光","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People1","direction":4,"pattern":1,"characterIndex":2},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"阿光"]},{"code":401,"indent":1,"parameters":["阿光胸一挺，明明只是在藥鋪裡，也像準備對天地立誓。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"阿光"]},{"code":401,"indent":1,"parameters":["你剛靠近，阿光就壓低聲音。"]},{"code":401,"indent":1,"parameters":["可惜他自以為壓低的音量，還是能震到藥罐。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"阿光"]},{"code":401,"indent":1,"parameters":["阿光正摸著剛包好的手肘。"]},{"code":401,"indent":1,"parameters":["那神情像剛從一場拯救蒼生的大戰退下來，其實只是昨晚巡夜絆到石頭。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["阿光_選單"]},{"code":102,"indent":0,"parameters":[["問你在忙啥","說說鄰居","翻我黑歷史","問村裡最近","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問你在忙啥"]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"阿光"]},{"code":401,"indent":1,"parameters":["我巡夜、巡街、巡可疑人物，總之村裡的夜色由我守。"]},{"code":401,"indent":1,"parameters":["雖然韓村長說我別每回都喊得像要決戰天下，但氣勢這種東西，少一分都不像樣。"]},{"code":401,"indent":1,"parameters":["你要是夜裡看到我，別怕，那多半只是正義在走路。"]},{"code":119,"indent":1,"parameters":["阿光_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"阿光"]},{"code":401,"indent":1,"parameters":["秋娘嘴上嫌我吵，真有事還不是先拿藥給我；阿蛇老想偷溜近路，每回都被我抓到。"]},{"code":401,"indent":1,"parameters":["阿松跑腿快，阿青看人準，我則負責把「不對勁」三個字喊得全村都知道。"]},{"code":401,"indent":1,"parameters":["一個村子要穩，不只要有人看，也要有人肯先站出去。"]},{"code":119,"indent":1,"parameters":["阿光_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"阿光"]},{"code":401,"indent":1,"parameters":["你小時候拿竹竿追著我跑，硬說那是「雙俠合擊陣」。"]},{"code":401,"indent":1,"parameters":["結果你衝太快先跌進水溝，我還得回頭把你拎起來。"]},{"code":401,"indent":1,"parameters":["從那天起我就懂，你的熱血常常跑在你的腳底板前面。"]},{"code":119,"indent":1,"parameters":["阿光_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"阿光"]},{"code":401,"indent":1,"parameters":["最近東邊舊路讓我不太放心，因為有人不是怕黑，是怕碰上巡夜的人。"]},{"code":401,"indent":1,"parameters":["怕黑的人會買燈，怕被看見的人才會專挑我繞遠的時辰問路。"]},{"code":401,"indent":1,"parameters":["若真有歪心思的人摸進來，我阿光第一個不答應。"]},{"code":119,"indent":1,"parameters":["阿光_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People1",2,0,2,"阿光"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":6,"y":7},{"id":5,"name":"阿蛇","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People2","direction":6,"pattern":1,"characterIndex":4},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"阿蛇"]},{"code":401,"indent":1,"parameters":["阿蛇一見你就露出那副「我這裡有門路」的表情。"]},{"code":401,"indent":1,"parameters":["你從小看他看到大，還是分不清他哪句是真，哪句是生意。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"阿蛇"]},{"code":401,"indent":1,"parameters":["阿蛇把包袱往腳邊一勾，聲音也跟著壓低。"]},{"code":401,"indent":1,"parameters":["可這村子裡誰不知道，他壓低聲音通常代表他要開始亂講。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"阿蛇"]},{"code":401,"indent":1,"parameters":["阿蛇先笑，後開口。"]},{"code":401,"indent":1,"parameters":["這套順序你太熟了，因為你小時候被他這樣哄去幫搬貨不止一回。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["阿蛇_選單"]},{"code":102,"indent":0,"parameters":[["問你在忙啥","說說鄰居","翻我黑歷史","問村裡最近","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問你在忙啥"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"阿蛇"]},{"code":401,"indent":1,"parameters":["我做的是消息加跑腿加小買賣，學名叫活絡村內生意，俗名叫哪裡有空隙我就往哪裡鑽。"]},{"code":401,"indent":1,"parameters":["秋娘缺藥罐、老趙缺麻繩、阿梅缺乾貨，很多時候都得靠我這雙腳補上。"]},{"code":401,"indent":1,"parameters":["你別老把我想得太壞，我只是比別人更早聞到哪邊有錢味。"]},{"code":119,"indent":1,"parameters":["阿蛇_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"阿蛇"]},{"code":401,"indent":1,"parameters":["阿光總覺得我鬼鬼祟祟，可他巡夜要不是靠我告訴他哪條巷子有人影，能省一半力？"]},{"code":401,"indent":1,"parameters":["老趙酒多話多，阿青話多腿快，這兩個一湊起來，半村消息都能起鍋。"]},{"code":401,"indent":1,"parameters":["你在這村長大，應該懂，能把話傳到對的人手上，也是一門真本事。"]},{"code":119,"indent":1,"parameters":["阿蛇_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"阿蛇"]},{"code":401,"indent":1,"parameters":["你小時候老想跟我學怎麼做生意，我就叫你先學會不要把銅板全拿去買糖。"]},{"code":401,"indent":1,"parameters":["結果你嘴上說要投資大業，轉頭就把本錢吃進肚子。"]},{"code":401,"indent":1,"parameters":["從那天起我就知道，你這人適合闖事，不太適合算帳。"]},{"code":119,"indent":1,"parameters":["阿蛇_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"阿蛇"]},{"code":401,"indent":1,"parameters":["最近東邊舊路的風聲熱，可真正值錢的不是風聲，是誰在提前備東西。"]},{"code":401,"indent":1,"parameters":["有的人問路，有的人買繩，有的人備藥，這三種湊在一起就不太像單純趕路。"]},{"code":401,"indent":1,"parameters":["你若真要查，記得少說兩句，多看別人手裡拿了什麼。"]},{"code":119,"indent":1,"parameters":["阿蛇_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People2",4,0,2,"阿蛇"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":10,"y":7}]}