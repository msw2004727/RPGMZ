","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"!Flame","direction":6,"pattern":1,"characterIndex":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["灶火燒得正穩，屋裡有股剛剛好的飯香。"]},{"code":401,"indent":0,"parameters":["你記得小時候聞到這味道就往屋裡鑽，然後被小桃逮去洗手。"]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":true}],"x":9,"y":2},{"id":2,"name":"西側灶火","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":true,"image":{"tileId":0,"characterName":"!Flame","direction":6,"pattern":1,"characterIndex":0},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["另一邊灶口也燒著小火，顯然這家人連忙碌都帶著溫度。"]},{"code":401,"indent":0,"parameters":["阿強常說，家裡火要穩，人才不會散；這話聽著土，倒很像真理。"]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":true,"through":false,"trigger":0,"walkAnime":true}],"x":7,"y":2},{"id":3,"name":"EV003","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":250,"indent":0,"parameters":[{"name":"Move1","volume":90,"pitch":100,"pan":0}]},{"code":201,"indent":0,"parameters":[0,1,2,23,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":1,"walkAnime":true}],"x":8,"y":11},{"id":4,"name":"小桃","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People1","direction":2,"pattern":1,"characterIndex":3},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["小桃正把屋裡收得整整齊齊，一見你來就先笑。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["小桃回頭看你一眼，那神情像在數你這回有沒有把腳上的泥帶進屋。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["你還沒開口，小桃就先說「別亂摸東西」。"]},{"code":401,"indent":1,"parameters":["看來你小時候留下的名聲還挺牢。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["小桃_選單"]},{"code":102,"indent":0,"parameters":[["問你在忙啥","說說鄰居","翻我黑歷史","問村裡最近","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問你在忙啥"]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["我在忙收屋子，也在忙盯阿強別把工具丟得到處都是。"]},{"code":401,"indent":1,"parameters":["村裡人看我笑得輕鬆，只有我知道每天都像在打一場家務擂台。"]},{"code":401,"indent":1,"parameters":["還好阿平修東西快，小禾補布也快，不然這屋子早被我們用壞三輪了。"]},{"code":119,"indent":1,"parameters":["小桃_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["阿強嘴上硬，真要幫鄰居搬東西時從不慢半步。"]},{"code":401,"indent":1,"parameters":["小禾總說我煮湯太鹹，阿梅又說這樣剛好配老趙的酒客。"]},{"code":401,"indent":1,"parameters":["你從小在這條街跑來跑去，應該最清楚，大家嘴上互刺，其實心都朝一邊。"]},{"code":119,"indent":1,"parameters":["小桃_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["你小時候來我家，最愛翻櫃子找零嘴。"]},{"code":401,"indent":1,"parameters":["我明明把餅藏得很高，你還硬說自己在施展「飛簷探寶步」。"]},{"code":401,"indent":1,"parameters":["最後餅沒偷成，人先從椅子上摔下來，阿強笑到差點把杯子摔了。"]},{"code":119,"indent":1,"parameters":["小桃_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["最近大家都在講東邊舊路，講得像那裡明天就要冒出十個魔頭。"]},{"code":401,"indent":1,"parameters":["我看哪，真正可怕的不是風聲，是一群人把風聲越炒越香。"]},{"code":401,"indent":1,"parameters":["不過真有事也別怕，咱村不是沒吵過，但真要站一起時從不含糊。"]},{"code":119,"indent":1,"parameters":["小桃_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People1",3,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":9,"y":5},{"id":5,"name":"阿強","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People1","direction":2,"pattern":1,"characterIndex":4},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["阿強剛把手上的木片放下，看起來正忙著補家裡的小毛病。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["阿強一看到你，就露出那種「你該不會又來借工具吧」的表情。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["阿強正準備出門，結果被你堵個正著。"]},{"code":401,"indent":1,"parameters":["他嘴上嘆氣，眼底倒還是笑的。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["阿強_選單"]},{"code":102,"indent":0,"parameters":[["問你在忙啥","說說鄰居","翻我黑歷史","問村裡最近","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問你在忙啥"]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["我在補家裡的門框，也在補小桃昨天嫌我沒收好的那點面子。"]},{"code":401,"indent":1,"parameters":["村裡房子不大，毛病不少，今天是窗，明天是桌腳，後天輪到水桶柄。"]},{"code":401,"indent":1,"parameters":["要我說，過日子最強的武功就一句話，壞了立刻修。"]},{"code":119,"indent":1,"parameters":["阿強_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["阿平手穩得像木頭都聽他話，阿梅則是一開口就能讓阿旺收心。"]},{"code":401,"indent":1,"parameters":["小桃嘴上念我，真有人找我幫忙，她又會先把飯留好。"]},{"code":401,"indent":1,"parameters":["這村裡沒有誰真靠一個人過，大家都是東拼一點、西補一點才活得順。"]},{"code":119,"indent":1,"parameters":["阿強_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["你小時候來借我斧頭，說要去山邊劈出一條少俠大道。"]},{"code":401,"indent":1,"parameters":["我當場把你趕回去，因為你那時連斧柄該怎麼握都還沒懂。"]},{"code":401,"indent":1,"parameters":["你還不服，回頭拿木棍在路邊比畫半天，像個認真的笑話。"]},{"code":119,"indent":1,"parameters":["阿強_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["最近東邊舊路的話題多得很，可真正在意的人反倒講得少。"]},{"code":401,"indent":1,"parameters":["阿青在外頭看人，我這種做活的人則看手上的磨痕和鞋底的泥。"]},{"code":401,"indent":1,"parameters":["有些人是趕路，有些人是藏路，分別都寫在小地方。"]},{"code":119,"indent":1,"parameters":["阿強_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People1",4,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":8,"y":5}]}