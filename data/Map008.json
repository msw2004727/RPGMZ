{"id":4,"name":"小桃","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"SF_Actor2","direction":2,"pattern":1,"characterIndex":1},"list":[{"code":101,"indent":0,"parameters":["SF_Actor2",1,0,2,"小桃"]},{"code":401,"indent":0,"parameters":["呀！有客人！快進來快進來！"]},{"code":401,"indent":0,"parameters":["我是小桃，這是我們的愛巢～"]},{"code":118,"indent":0,"parameters":["桃選單"]},{"code":102,"indent":0,"parameters":[["你們感情真好","隔壁那個怪人...","沒事了"],2,0,2,0]},{"code":402,"indent":0,"parameters":[0,"你們感情真好"]},{"code":101,"indent":1,"parameters":["SF_Actor2",1,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["那當然！我家阿強可是全村最好的男人！"]},{"code":401,"indent":1,"parameters":["他每天幫我做飯、洗衣服、按摩！"]},{"code":101,"indent":1,"parameters":["SF_Actor2",1,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["昨天還偷偷用私房錢幫我買了新髮簪！"]},{"code":401,"indent":1,"parameters":["你看你看～好不好看～"]},{"code":101,"indent":1,"parameters":["SF_Actor2",1,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["......什麼？他是不是被我逼的？"]},{"code":401,"indent":1,"parameters":["我只是溫柔地「建議」而已！"]},{"code":401,"indent":1,"parameters":["很溫柔的那種！拳頭大小的溫柔！"]},{"code":119,"indent":1,"parameters":["桃選單"]},{"code":402,"indent":0,"parameters":[1,"隔壁那個怪人..."]},{"code":101,"indent":1,"parameters":["SF_Actor2",1,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["唉，別提了！隔壁那個老周超難搞！"]},{"code":101,"indent":1,"parameters":["SF_Actor2",1,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["上次我跟阿強在家慶祝結婚紀念日，"]},{"code":401,"indent":1,"parameters":["就......稍微開心了一點嘛，"]},{"code":401,"indent":1,"parameters":["他居然跑來敲門說我們在虐貓！？"]},{"code":101,"indent":1,"parameters":["SF_Actor2",1,0,2,"小桃"]},{"code":401,"indent":1,"parameters":["拜託！我們家根本沒養貓好嗎！"]},{"code":401,"indent":1,"parameters":["我們只是在表達夫妻之間深厚的愛！"]},{"code":401,"indent":1,"parameters":["......用比較大聲的方式而已！"]},{"code":401,"indent":1,"parameters":["有什麼問題嗎！"]},{"code":119,"indent":1,"parameters":["桃選單"]},{"code":402,"indent":0,"parameters":[2,"沒事了"]},{"code":101,"indent":0,"parameters":["SF_Actor2",1,0,2,"小桃"]},{"code":401,"indent":0,"parameters":["好的～有空常來坐！"]},{"code":401,"indent":0,"parameters":["對了，要是你碰到隔壁那個怪人，"]},{"code":401,"indent":0,"parameters":["替我跟他說：我！們！不！養！貓！"]},{"code":401,"indent":0,"parameters":["真的沒有貓！一隻都沒有！"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":9,"y":5},
{"id":5,"name":"阿強","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People1","direction":2,"pattern":1,"characterIndex":0},"list":[{"code":101,"indent":0,"parameters":["People1",0,0,2,"阿強"]},{"code":401,"indent":0,"parameters":["啊......你好你好......"]},{"code":118,"indent":0,"parameters":["強選單"]},{"code":102,"indent":0,"parameters":[["嫂子看起來很開心","你幸福嗎？","告辭"],2,0,2,0]},{"code":402,"indent":0,"parameters":[0,"嫂子看起來很開心"]},{"code":101,"indent":1,"parameters":["People1",0,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["哈哈......是啊......很幸福......"]},{"code":401,"indent":1,"parameters":["（小聲）其實我的私房錢已經見底了......"]},{"code":101,"indent":1,"parameters":["People1",0,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["但只要老婆開心就好！這就是愛！"]},{"code":401,"indent":1,"parameters":["......等等你千萬不要跟她說我沒錢了啊！"]},{"code":401,"indent":1,"parameters":["她會讓我跪到天亮的！"]},{"code":119,"indent":1,"parameters":["強選單"]},{"code":402,"indent":0,"parameters":[1,"你幸福嗎？"]},{"code":101,"indent":1,"parameters":["People1",0,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["幸福！當然幸福！必須幸福！"]},{"code":401,"indent":1,"parameters":["我老婆說了，不幸福的話——"]},{"code":101,"indent":1,"parameters":["People1",0,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["嗯......你看到門口那塊搓衣板了嗎？"]},{"code":401,"indent":1,"parameters":["那不是拿來洗衣服的。"]},{"code":401,"indent":1,"parameters":["那是拿來跪的。"]},{"code":101,"indent":1,"parameters":["People1",0,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["所以我每天都非常、非常幸福。"]},{"code":401,"indent":1,"parameters":["（眼神死）"]},{"code":401,"indent":1,"parameters":["真的。"]},{"code":119,"indent":1,"parameters":["強選單"]},{"code":402,"indent":0,"parameters":[2,"告辭"]},{"code":101,"indent":1,"parameters":["People1",0,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["慢走啊兄弟......"]},{"code":401,"indent":1,"parameters":["（小聲）帶我走......"]},{"code":101,"indent":1,"parameters":["People1",0,0,2,"阿強"]},{"code":401,"indent":1,"parameters":["開玩笑的！我很幸福！真的！"]},{"code":401,"indent":1,"parameters":["......老婆妳不要瞪我啊！"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":8,"y":5}
