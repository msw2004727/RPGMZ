:1,"parameters":["村子小歸小，可一旦大家同時開口，紙就能堆得像半面牆。"]},{"code":401,"indent":1,"parameters":["真要說江湖絕學，我這招叫「亂事收束手」。"]},{"code":119,"indent":1,"parameters":["蘭姨_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People1",5,0,2,"蘭姨"]},{"code":401,"indent":1,"parameters":["阿安做事細，阿青跑得快，韓村長決斷穩，三個人湊一起才撐得住前頭那堆村務。"]},{"code":401,"indent":1,"parameters":["阿平報修繕、阿梅報住客、老趙報消息，連秋娘都會把誰最近常上藥寫來提醒。"]},{"code":401,"indent":1,"parameters":["這村從來不是誰單打獨鬥撐住的。"]},{"code":119,"indent":1,"parameters":["蘭姨_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People1",5,0,2,"蘭姨"]},{"code":401,"indent":1,"parameters":["你小時候最愛趁我不注意摸走廢紙，說要拿去畫你的江湖秘圖。"]},{"code":401,"indent":1,"parameters":["結果圖沒畫出幾張，倒把我登記糧袋的空白頁用掉一半。"]},{"code":401,"indent":1,"parameters":["我到現在看到你靠近桌案，第一反應還是先壓住紙。"]},{"code":119,"indent":1,"parameters":["蘭姨_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People1",5,0,2,"蘭姨"]},{"code":401,"indent":1,"parameters":["最近東邊舊路的事讓大家心裡都繃著，可越是這時候，越不能讓村裡自己先亂。"]},{"code":401,"indent":1,"parameters":["韓村長盯大事，我盯細節，阿安盯流程，阿青盯風吹草動。"]},{"code":401,"indent":1,"parameters":["你若想幫忙，就把聽到的話帶完整，別只帶最熱鬧的那半句。"]},{"code":119,"indent":1,"parameters":["蘭姨_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People1",5,0,2,"蘭姨"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":15,"y":6}]}