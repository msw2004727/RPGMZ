,"parameters":[3,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People4",1,0,2,"阿梅"]},{"code":401,"indent":1,"parameters":["你小時候最愛在大廳長椅上裝昏，想混一碗免費熱湯。"]},{"code":401,"indent":1,"parameters":["結果每回都露餡，因為你一聞到肉香，眼皮就先抖。"]},{"code":401,"indent":1,"parameters":["我那時就說過，你要闖江湖可以，先把裝死這門功課修好。"]},{"code":119,"indent":1,"parameters":["阿梅_選單"]},{"code":402,"indent":0,"parameters":[4,"問最近風聲"]},{"code":101,"indent":1,"parameters":["People4",1,0,2,"阿梅"]},{"code":401,"indent":1,"parameters":["最近往東邊舊路打聽的人變多，嘴上說是問路，眼睛卻像在量距離。"]},{"code":401,"indent":1,"parameters":["老趙聞得出酒味，我看得出住客心事，秋娘則連誰晚上沒睡好都知道。"]},{"code":401,"indent":1,"parameters":["真有什麼不對勁，村裡幾張老面孔很快就會串成一條線。"]},{"code":119,"indent":1,"parameters":["阿梅_選單"]},{"code":402,"indent":0,"parameters":[5,"先走"]},{"code":101,"indent":1,"parameters":["People4",1,0,2,"阿梅"]},{"code":401,"indent":1,"parameters":["累了就回來歇。"]},{"code":401,"indent":1,"parameters":["這門一直給自己人開著，前提是別帶麻煩進來。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":5,"y":5},{"id":7,"name":"劉叔","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People4","direction":2,"pattern":1,"characterIndex":6},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People4",6,0,2,"劉叔"]},{"code":401,"indent":1,"parameters":["劉叔才剛坐下，靴子邊還沾著田裡的泥。"]},{"code":401,"indent":1,"parameters":["一看就是今天又從地頭忙到天黑。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People4",6,0,2,"劉叔"]},{"code":401,"indent":1,"parameters":["你一靠近，劉叔就拍了拍腿。"]},{"code":401,"indent":1,"parameters":["那意思像在說「有話快問，等會兒我就要睡著了」。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People4",6,0,2,"劉叔"]},{"code":401,"indent":1,"parameters":["劉叔把草帽擱在一旁，整個人還帶著白天曬過的熱氣。"]},{"code":401,"indent":1,"parameters":["他看你時，像又想起你小時候亂踩秧苗那回事。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["劉叔_選單"]},{"code":102,"indent":0,"parameters":[["問你在忙啥","說說鄰居","翻我黑歷史","問村裡最近","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問你在忙啥"]},{"code":101,"indent":1,"parameters":["People4",6,0,2,"劉叔"]},{"code":401,"indent":1,"parameters":["我白天在田裡，晚上若懶得走回西邊，就來阿梅這裡借一張床。"]},{"code":401,"indent":1,"parameters":["地裡的活看著樸素，其實比很多江湖招式都磨人，少一個天時就得改整套節奏。"]},{"code":401,"indent":1,"parameters":["你若真想懂過日子，先學會尊重一粒米是怎麼長出來的。"]},{"code":119,"indent":1,"parameters":["劉叔_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People4",6,0,2,"劉叔"]},{"code":401,"indent":1,"parameters":["阿平補屋、阿梅顧人、秋娘顧命，少了哪一個，村子都得漏風。"]},{"code":401,"indent":1,"parameters":["春生跑腿跑得快，阿松傳話傳得快，結果嘴最快的還是阿青。"]},{"code":401,"indent":1,"parameters":["咱村人吵歸吵，真有人跌一跤，伸手的速度倒是一個比一個快。"]},{"code":119,"indent":1,"parameters":["劉叔_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People4",6,0,2,"劉叔"]},{"code":401,"indent":1,"parameters":["你小時候衝進田裡，說要練什麼「踏雲輕功」。"]},{"code":401,"indent":1,"parameters":["結果輕功沒練成，秧苗倒讓你踏出一條求救路。"]},{"code":401,"indent":1,"parameters":["我追著你跑半塊田，你還邊跑邊喊自己是在測地勢。"]},{"code":119,"indent":1,"parameters":["劉叔_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People4",6,0,2,"劉叔"]},{"code":401,"indent":1,"parameters":["最近東邊那條舊路讓人不太安心，泥印比平常雜，還多了些不熟的鞋底痕。"]},{"code":401,"indent":1,"parameters":["真正下田的人看路，跟真正趕路的人踩地，力道是不一樣的。"]},{"code":401,"indent":1,"parameter