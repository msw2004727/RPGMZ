code":401,"indent":1,"parameters":["我替村裡送貨，酒、布、藥、木料，哪邊缺什麼就往哪邊跑。"]},{"code":401,"indent":1,"parameters":["有時一天能先去阿梅這裡搬桶，再替秋娘送藥，最後還得去老趙那邊扛空甕。"]},{"code":401,"indent":1,"parameters":["別人練輕功靠秘笈，我練腿靠全村使喚。"]},{"code":119,"indent":1,"parameters":["春生_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People1",0,0,2,"春生"]},{"code":401,"indent":1,"parameters":["阿梅嘴上兇，累到真的站不穩時，她還是會先端碗湯給人。"]},{"code":401,"indent":1,"parameters":["阿蛇整天說自己門路廣，我看他有一半門路其實是跟阿松打聽來的。"]},{"code":401,"indent":1,"parameters":["你從小在這裡長大應該懂，咱村的消息不是寫在紙上，是跑在路上。"]},{"code":119,"indent":1,"parameters":["春生_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People1",0,0,2,"春生"]},{"code":401,"indent":1,"parameters":["你小時候把一包豆子塞給我，說那是「江湖密件」，叫我送到阿青手裡。"]},{"code":401,"indent":1,"parameters":["結果袋子半路破了，整條路像被灑了追魂暗器。"]},{"code":401,"indent":1,"parameters":["阿青看到時差點笑翻，說你連秘密都漏得很平均。"]},{"code":119,"indent":1,"parameters":["春生_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People1",0,0,2,"春生"]},{"code":401,"indent":1,"parameters":["最近往東邊去的人問路問得勤，可真肯把名字留下來的沒幾個。"]},{"code":401,"indent":1,"parameters":["會正大光明趕路的人通常不怕別人記，越遮遮掩掩的，越像肚裡有鬼。"]},{"code":401,"indent":1,"parameters":["我腿快，但我也知道，有些路不是快就夠，還得看得細。"]},{"code":119,"indent":1,"parameters":["春生_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People1",0,0,2,"春生"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":12,"y":4},{"id":9,"name":"阿旺","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People_ex1","direction":2,"pattern":1,"characterIndex":3},"list":[{"code":122,"indent":0,"parameters":[1,1,0,2,0,2]},{"code":111,"indent":0,"parameters":[1,1,0,0,0]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"阿旺"]},{"code":401,"indent":1,"parameters":["阿旺本來還想裝忙，一看見是你，抹布就藏不住了。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,1,0]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"阿旺"]},{"code":401,"indent":1,"parameters":["阿旺靠在柱邊發呆，被你撞見後立刻站直。"]},{"code":401,"indent":1,"parameters":["那速度堪稱旅館絕學。"]},{"code":412,"indent":0,"parameters":[]},{"code":111,"indent":0,"parameters":[1,1,0,2,0]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"阿旺"]},{"code":401,"indent":1,"parameters":["阿旺嘴裡還哼著不成調的小曲。"]},{"code":401,"indent":1,"parameters":["你聽兩句就知道，這人十之八九又想偷懶。"]},{"code":412,"indent":0,"parameters":[]},{"code":118,"indent":0,"parameters":["阿旺_選單"]},{"code":102,"indent":0,"parameters":[["問你在忙啥","說說鄰居","翻我黑歷史","問村裡最近","先走"],4,0,2,0]},{"code":402,"indent":0,"parameters":[0,"問你在忙啥"]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"阿旺"]},{"code":401,"indent":1,"parameters":["我娘說我在學顧旅館，實話就是搬水、抹桌、顧櫃台、順便被她盯。"]},{"code":401,"indent":1,"parameters":["等我哪天真把帳記明白，說不定就能自封「客棧少掌櫃」。"]},{"code":401,"indent":1,"parameters":["目前嘛，我比較像「毛巾守護使」。"]},{"code":119,"indent":1,"parameters":["阿旺_選單"]},{"code":402,"indent":0,"parameters":[1,"說說鄰居"]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"阿旺"]},{"code":401,"indent":1,"parameters":["小禾手比我快，阿梅眼比我利，春生腿比我能跑。"]},{"code":401,"indent":1,"parameters":["但真有醉鬼鬧事，第一個被推出去擋門的還是我。"]},{"code":401,"indent":1,"parameters":["你要笑可以，記得小時候被推出去頂鍋的也常常是你。"]},{"code":119,"indent":1,"parameters":["阿旺_選單"]},{"code":402,"indent":0,"parameters":[2,"翻我黑歷史"]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"阿旺"]},{"code":401,"indent":1,"parameters":["你小時候最愛跟我比誰能在大廳柱子後面躲最久。"]},{"code":401,"indent":1,"parameters":["結果每次都先忍不住偷看廚房，然後被阿梅一眼抓包。"]},{"code":401,"indent":1,"parameters":["我到現在都懷疑，你那不叫潛伏，叫朝著肉包子自投羅網。"]},{"code":119,"indent":1,"parameters":["阿旺_選單"]},{"code":402,"indent":0,"parameters":[3,"問村裡最近"]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"阿旺"]},{"code":401,"indent":1,"parameters":["最近旅館住客多了點，來的人嘴上說路過，耳朵卻都在聽東邊舊路。"]},{"code":401,"indent":1,"parameters":["阿梅表面照收錢照招呼，實際上每個人的步子她都記在心裡。"]},{"code":401,"indent":1,"parameters":["這村啊，看似鬆，其實誰有異樣，熟人一眼就能挑出來。"]},{"code":119,"indent":1,"parameters":["阿旺_選單"]},{"code":402,"indent":0,"parameters":[4,"先走"]},{"code":101,"indent":1,"parameters":["People_ex1",3,0,2,"阿旺"]},{"code":401,"indent":1,"parameters":["行，你先忙。"]},{"code":401,"indent":1,"parameters":["我也繼續在村裡晃一圈。"]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":14,"y":11}]}